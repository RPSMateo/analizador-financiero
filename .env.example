# Copiá este archivo a .env.local y completá los valores para desarrollo local.

# Credenciales de Supabase (ver SUPABASE_SETUP.md)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Mercado Pago — Access Token de producción
# Obtenelo en https://www.mercadopago.com.ar/developers/panel/credentials
MP_ACCESS_TOKEN=

# URL base de la app (para back_urls de Mercado Pago en local)
# En producción Vercel lo resuelve automáticamente desde el header Origin
NEXT_PUBLIC_APP_URL=http://localhost:3000
